# =============================================================================
# fund-indicators .gitignore
# =============================================================================

# ── Dependencies ──
node_modules/
jspm_packages/

# ── Build output ──
dist/
build/
*.tsbuildinfo

# ── Package manager ──
package-lock.json
yarn.lock
pnpm-lock.yaml
.npmrc

# ── Testing & Coverage ──
coverage/
.nyc_output/
*.lcov
.jest/

# ── IDE & Editor ──
.vscode/
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# ── OS files ──
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ── Environment & Secrets ──
.env
.env.*
!.env.example
*.pem
*.key
secrets.json
credentials.json

# ── Logs ──
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
pnpm-debug.log*

# ── Runtime data ──
pids/
*.pid
*.seed
*.pid.lock

# ── Temporary files ──
tmp/
temp/
.cache/
.parcel-cache/
.turbo/

# ── Misc ──
*.bak
*.orig
*.diff
.eslintcache
