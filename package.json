{
  "name": "@stvy/fund-indicators",
  "version": "1.0.6",
  "description": "基金自动化交易指标计算工具库 - 基于历史净值计算全部技术指标",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "scripts": {
    "build": "pnpm run build:node && pnpm run build:browser",
    "build:node": "pkgroll",
    "build:browser": "node build-browser.mjs",
    "test": "tsx test/index.test.ts",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "simple-statistics": "^7.8.0"
  },
  "devDependencies": {
    "technicalindicators": "^3.1.0",
    "jstat": "^1.9.6",
    "typescript": "^6",
    "esbuild": "latest",
    "pkgroll": "^2",
    "tsx": "^4"
  },
  "optionalDependencies": {
    "@types/node": "latest"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@11.1.1",
  "keywords": [
    "fund",
    "fund-nav",
    "technical-indicators",
    "quantitative",
    "quantitative-finance",
    "trading",
    "backtest",
    "moving-average",
    "macd",
    "rsi",
    "kdj",
    "bollinger-bands",
    "sharpe-ratio",
    "max-drawdown",
    "var",
    "hurst-exponent",
    "dca",
    "typescript",
    "browser"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/stevieyu/fund-indicators.git"
  },
  "homepage": "https://github.com/stevieyu/fund-indicators#readme",
  "bugs": {
    "url": "https://github.com/stevieyu/fund-indicators/issues"
  }
}
